# ╔══════════════════════════════════════════════════════════════════╗
# ║                    🏦 BankFlow                                 ║
# ║        Banking & Transaction Management System                 ║
# ╚══════════════════════════════════════════════════════════════════╝
#
# Production-grade fintech application featuring:
#   • PostgreSQL ACID transactions with stored procedures
#   • Redis cache-aside pattern with TTL invalidation
#   • JWT authentication with role-based access control
#   • Real-time fraud detection engine
#   • Recharts analytics dashboard
#
# ──────────────────────────────────────────────────────────────────
#                      SECURITY NOTICE
# ──────────────────────────────────────────────────────────────────
# All secrets are loaded from .env files (git-ignored).
# NEVER commit .env files or hardcode credentials.
# See .env.example files in /server and /client for templates.
# ──────────────────────────────────────────────────────────────────

# ========================
# SERVER CONFIGURATION
# ========================
# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bankflow
DB_USER=bankflow_admin
DB_PASSWORD=<CHANGE_ME_TO_STRONG_PASSWORD>
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis connection
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<CHANGE_ME>
REDIS_TTL_SECONDS=300

# JWT secrets — generate via: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=<GENERATE_AND_PASTE_HERE>
JWT_REFRESH_SECRET=<GENERATE_AND_PASTE_HERE>
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Server
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========================
# CLIENT CONFIGURATION
# ========================
# VITE_API_BASE_URL=http://localhost:5000/api/v1
