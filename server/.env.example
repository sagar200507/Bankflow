# ========================
# SERVER ENVIRONMENT
# ========================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bankflow
DB_USER=bankflow_admin
DB_PASSWORD=<CHANGE_ME_TO_STRONG_PASSWORD>
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL_SECONDS=300

# JWT — generate via: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=<GENERATE_AND_PASTE_HERE>
JWT_REFRESH_SECRET=<GENERATE_AND_PASTE_HERE>
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Server
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
