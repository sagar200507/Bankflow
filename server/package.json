{
  "name": "bankflow-server",
  "version": "1.0.0",
  "description": "BankFlow — Banking & Transaction Management System (Backend)",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "test": "jest --coverage --forceExit --detectOpenHandles",
    "test:unit": "jest --testPathPattern=tests/unit --coverage",
    "test:integration": "jest --testPathPattern=tests/integration --forceExit --detectOpenHandles",
    "test:load": "k6 run tests/load/stress.js",
    "db:migrate": "node src/db/migrations/run.js",
    "db:seed": "node src/db/seeds/run.js",
    "db:procedures": "node src/db/procedures/run.js",
    "lint": "eslint src/ --ext .js"
  },
  "keywords": ["fintech", "banking", "postgresql", "redis", "jwt"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.13.0",
    "uuid": "^10.0.0",
    "winston": "^3.14.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  }
}
